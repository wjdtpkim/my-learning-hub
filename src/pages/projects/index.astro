---
import Base from '../../layouts/Base.astro';
import { getProjects } from '../../lib/content';

const projects = await getProjects();
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title="프로젝트" wide>
  <h1 class="page-title">프로젝트</h1>
  <p class="page-desc">내가 만드는 것들. 다 만들면 <code>status</code>를 <code>완성</code>으로 바꾸면 배지가 초록으로 바뀌어요.</p>

  {projects.length === 0 ? (
    <div class="empty">아직 프로젝트가 없어요. <code>src/content/projects/</code>에 .md를 넣어보세요.</div>
  ) : (
    <div class="card-grid">
      {projects.map((p) => (
        <a href={`/projects/${p.slug}`} class="card">
          <div>
            <span class:list={['badge', p.data.status]}>{p.data.status}</span>
            {p.data.tags?.slice(0, 2).map((t) => (
              <span class="tags"> #{t}</span>
            ))}
          </div>
          <h3>{p.data.title}</h3>
          {p.data.summary && <p class="summary">{p.data.summary}</p>}
          <div class="meta">{fmt(p.data.date)}</div>
        </a>
      ))}
    </div>
  )}
</Base>
