---
import Header from '../components/Header.astro';
import { site } from '../config/site';

export interface Props {
  title?: string;
  description?: string;
  wide?: boolean;   // 목록 페이지처럼 넓은 폭이 필요할 때 true
  full?: boolean;   // 위키 3단처럼 화면을 꽉 채워야 할 때 true
}

const { title, description = site.기본소개, wide = false, full = false } = Astro.props;
const fullTitle = title ? `${title} · ${site.이름}` : site.이름;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />
    <main class:list={['main', { wide, full }]}>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {site.이름}</p>
    </footer>

    <style is:global>
      :root {
        --bg: #ffffff;
        --surface: #f5f5f4;
        --fg: #1c1917;
        --muted: #78716c;
        --line: #e7e5e4;
        --accent: #1c1917;
        --green-bg: #dcfce7;
        --green-fg: #15803d;
        --amber-bg: #fef3c7;
        --amber-fg: #b45309;
        --header-height: 56px;
        --radius: 14px;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: 'Pretendard', -apple-system, BlinkMacSystemFont,
          'Segoe UI', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
        font-size: 16px;
        line-height: 1.7;
        word-break: keep-all;
      }

      a { color: inherit; }

      .main {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.25rem;
        min-height: calc(100vh - var(--header-height) - 80px);
      }
      .main.wide { max-width: 960px; }
      .main.full { max-width: 1240px; padding-left: 1.25rem; padding-right: 1.25rem; }

      .site-footer {
        border-top: 1px solid var(--line);
        text-align: center;
        color: var(--muted);
        font-size: 0.85rem;
        padding: 1.5rem;
      }

      /* ── 공용: 배지 (진행중=앰버 / 완성=초록) ───────────────── */
      .badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
      }
      .badge.진행중 { background: var(--amber-bg); color: var(--amber-fg); }
      .badge.완성   { background: var(--green-bg); color: var(--green-fg); }

      /* ── 공용: 카드 그리드 ──────────────────────────────── */
      .card-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 640px) {
        .card-grid { grid-template-columns: 1fr 1fr; }
      }
      .card {
        display: block;
        padding: 1.15rem 1.25rem;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        text-decoration: none;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .card:hover {
        border-color: var(--muted);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
      }
      .card h3 { margin: 0.4rem 0 0.3rem; font-size: 1.05rem; }
      .card .summary { margin: 0; font-size: 0.9rem; color: var(--muted); }
      .card .meta { font-size: 0.78rem; color: var(--muted); margin-top: 0.5rem; }
      .card .tags { font-size: 0.78rem; color: var(--muted); }

      /* ── 공용: 페이지 헤더 ──────────────────────────────── */
      .page-title { font-size: 1.9rem; font-weight: 700; margin: 0 0 0.4rem; }
      .page-desc  { color: var(--muted); margin: 0 0 2rem; }

      /* ── 공용: 빈 상태 안내 ─────────────────────────────── */
      .empty {
        padding: 3rem 1.5rem;
        border-radius: var(--radius);
        background: var(--surface);
        text-align: center;
        color: var(--muted);
      }

      /* ── 공용: 마크다운 본문(.prose) ────────────────────── */
      .prose { font-size: 1.02rem; }
      .prose h2 { margin-top: 2.2rem; font-size: 1.4rem; border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; }
      .prose h3 { margin-top: 1.6rem; font-size: 1.15rem; }
      .prose img { max-width: 100%; border-radius: 10px; }
      .prose pre { padding: 1rem; border-radius: 10px; overflow-x: auto; font-size: 0.88rem; }
      .prose code { font-size: 0.9em; }
      .prose blockquote {
        margin: 1.2rem 0;
        padding: 0.4rem 1rem;
        border-left: 3px solid var(--line);
        color: var(--muted);
      }
      .prose a { text-decoration: underline; text-underline-offset: 2px; }

      .back-link {
        display: inline-block;
        font-size: 0.88rem;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 1.5rem;
      }
      .back-link:hover { color: var(--fg); }

      /* ── 코드블록 복사 버튼 ────────────────────────────── */
      .prose pre { position: relative; }
      .prose .copy-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        padding: 0.2rem 0.6rem;
        font-size: 0.72rem;
        background: rgba(0, 0, 0, 0.08);
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.15s;
        color: inherit;
        font-family: inherit;
      }
      .prose pre:hover .copy-btn { opacity: 1; }
      .prose .copy-btn.copied {
        background: rgba(0, 160, 80, 0.12);
        border-color: rgba(0, 160, 80, 0.3);
        color: #0a7a40;
        opacity: 1;
      }

      /* ── 용어 툴팁 ─────────────────────────────────────── */
      .glossary-term {
        border-bottom: 1px dashed var(--muted);
        cursor: help;
        position: relative;
      }
      .glossary-term::before {
        content: '';
        position: absolute;
        bottom: calc(100% + 2px);
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: #1e1e1e;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 101;
      }
      .glossary-term::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: calc(100% + 12px);
        left: 50%;
        transform: translateX(-50%);
        background: #1e1e1e;
        color: #f0f0f0;
        font-size: 0.72rem;
        line-height: 1.5;
        padding: 0.35rem 0.6rem;
        border-radius: 5px;
        width: max-content;
        max-width: min(220px, 80vw);
        white-space: normal;
        text-align: center;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 100;
      }
      .glossary-term:hover::before,
      .glossary-term:hover::after { opacity: 1; }
    </style>
  </body>
</html>
